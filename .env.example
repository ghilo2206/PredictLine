# Copy this file to .env and fill in real values locally.
# NEVER commit a real .env file to version control.

# Database connection (TimescaleDB / PostgreSQL) — used when real telemetry
# ingestion is wired up; not required to run the synthetic demo in this repo.
DATABASE_URL=postgresql://user:password@localhost:5432/predictline

# API auth secret (JWT signing key) — generate a real random secret locally,
# e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET_KEY=replace-me-with-a-real-random-secret

# Optional: cloud GPU / ZCHPC CCE credentials for training jobs
ZCHPC_CCE_API_KEY=replace-me
ZCHPC_CCE_ENDPOINT=https://replace-with-real-endpoint

# Optional: notification layer (SMS/WhatsApp/email alerting)
NOTIFICATION_PROVIDER_API_KEY=replace-me
